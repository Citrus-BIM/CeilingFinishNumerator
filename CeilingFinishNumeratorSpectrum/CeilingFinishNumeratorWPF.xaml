<Window x:Class="CeilingFinishNumerator.CeilingFinishNumeratorWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Нумератор потолка"
        Height="560" Width="380"
        MinHeight="560" MinWidth="380"
        MaxHeight="560" MaxWidth="380"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Icon="Resources/citrus.ico"
        WindowStartupLocation="CenterScreen"
        KeyDown="CeilingFinishNumeratorWPF_KeyDown"

        FontFamily="{DynamicResource BaseFont}"
        FontSize="{DynamicResource FontSizeBase}"
        Foreground="{DynamicResource TextBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Language="ru-RU">

    <!-- Citrus theme -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- замени assembly при необходимости -->
                <ResourceDictionary Source="/CeilingFinishNumerator;component/CitrusTheme/CitrusTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== CONTENT ===================== -->
        <StackPanel Grid.Row="0" Margin="0,10,0,0">

            <!-- НУМЕРАЦИЯ -->
            <GroupBox x:Name="groupBox_CeilingFinishNumbering"
                      Header="Нумерация потолка:"
                      Margin="0,0,0,10">
                <StackPanel Margin="8,6,8,8">

                    <RadioButton x:Name="rbt_EndToEndThroughoutTheProject"
                                 Content="Сквозная по всему проекту"
                                 GroupName="CeilingFinishGroup"
                                 IsChecked="True"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"
                                 Checked="RadioButton_Checked"/>

                    <RadioButton x:Name="rbt_SeparatedByLevels"
                                 Content="С разделением по уровням"
                                 GroupName="CeilingFinishGroup"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"
                                 Checked="RadioButton_Checked"/>

                    <!-- Подблок выбора уровня (визуально отделён, но без смены логики) -->
                    <Border Padding="10,8"
                            CornerRadius="6"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="checkBox_ProcessSelectedLevel"
                                      Content="Обрабатывать только выбранный уровень"
                                      VerticalContentAlignment="Center"
                                      Margin="0,0,0,8"
                                      IsEnabled="{Binding ElementName=rbt_SeparatedByLevels, Path=IsChecked}"
                                      Checked="CheckBox_ProcessSelectedLevel_Checked"
                                      Unchecked="CheckBox_ProcessSelectedLevel_Checked"/>

                            <ComboBox x:Name="comboBox_LevelSelection"
                                      Grid.Row="1"
                                      Height="32"
                                      VerticalContentAlignment="Center"
                                      Margin="0,0,0,0"
                                      IsEnabled="{Binding ElementName=checkBox_ProcessSelectedLevel, Path=IsChecked}"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </GroupBox>

            <!-- ДОПОЛНИТЕЛЬНО -->
            <GroupBox Header="Дополнительно:"
                      Margin="0,0,0,0">
                <StackPanel Margin="8,6,8,8">

                    <CheckBox x:Name="checkBox_SeparatedBySections"
                              Content="С разделением по секциям"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,8"
                              Checked="CheckBox_StateChanged"
                              Unchecked="CheckBox_StateChanged"/>

                    <ComboBox x:Name="comboBox_RoomParameters"
                              Height="32"
                              VerticalContentAlignment="Center"
                              Margin="10,0,10,10"
                              IsEnabled="False"/>

                    <Separator Margin="0,0,0,10"/>

                    <CheckBox x:Name="checkBox_ConsiderPhase"
                              Content="Учитывать стадию"
                              VerticalContentAlignment="Center"
                              Margin="0"
                              Checked="CheckBox_Phase_StateChanged"
                              Unchecked="CheckBox_Phase_StateChanged"/>

                    <DockPanel Margin="22,6,0,0"
                               LastChildFill="True">
                        <Label Content="Стадия:"
                               Height="32"
                               Padding="0"
                               VerticalContentAlignment="Center"
                               Margin="0,0,8,0"/>
                        <ComboBox x:Name="comboBox_Phase"
                                  MinWidth="190"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  IsEnabled="False"/>
                    </DockPanel>

                    <DockPanel Margin="22,6,0,0"
                               LastChildFill="True">
                        <Label Content="Фильтр:"
                               Height="32"
                               Padding="0"
                               VerticalContentAlignment="Center"
                               Margin="0,0,8,0"/>
                        <ComboBox x:Name="comboBox_PhaseFilter"
                                  MinWidth="190"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  IsEnabled="False"/>
                    </DockPanel>

                    <Separator Margin="0,10,0,10"/>

                    <CheckBox x:Name="checkBox_FillRoomBookParameters"
                              Content='Заполнить параметры "RoomBook"'
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,0"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- ===================== BUTTONS (не меняем набор) ===================== -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button x:Name="btn_Ok"
                        Content="Ок"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="0,0,5,0"
                        IsDefault="True"
                        Click="btn_Ok_Click"/>
                <Button x:Name="btn_Cancel"
                        Content="Отмена"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="5,0,0,0"
                        IsCancel="True"
                        Style="{StaticResource ButtonOutline}"
                        Click="btn_Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
